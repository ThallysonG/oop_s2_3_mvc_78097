@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance Record";
}

<h1>Delete Attendance Record</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<dl class="row">
    <dt class="col-sm-2">Student</dt>
    <dd class="col-sm-10">@Model.CourseEnrolment?.StudentProfile?.Name</dd>

    <dt class="col-sm-2">Course</dt>
    <dd class="col-sm-10">@Model.CourseEnrolment?.Course?.Name</dd>

    <dt class="col-sm-2">Week</dt>
    <dd class="col-sm-10">@Model.WeekNumber</dd>

    <dt class="col-sm-2">Present</dt>
    <dd class="col-sm-10">@(Model.Present ? "Yes" : "No")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
