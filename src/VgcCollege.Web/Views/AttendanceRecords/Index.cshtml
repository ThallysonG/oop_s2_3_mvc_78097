@model IEnumerable<VgcCollege.Web.Models.AttendanceRecord>

@{
    ViewData["Title"] = "Attendance Records";
}

<h1>Attendance Records</h1>

@if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Attendance Record</a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Student</th>
            <th>Course</th>
            <th>Week</th>
            <th>Present</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseEnrolment?.StudentProfile?.Name</td>
                <td>@item.CourseEnrolment?.Course?.Name</td>
                <td>@item.WeekNumber</td>
                <td>@(item.Present ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    }

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
