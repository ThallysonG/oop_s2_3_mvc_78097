@model IEnumerable<VgcCollege.Web.Models.AttendanceRecord>

@{
    ViewData["Title"] = "My Attendance";
}

<h1>My Attendance</h1>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Course</th>
            <th>Branch</th>
            <th>Week</th>
            <th>Present</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseEnrolment?.Course?.Name</td>
                <td>@item.CourseEnrolment?.Course?.Branch?.Name</td>
                <td>@item.WeekNumber</td>
                <td>@(item.Present ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>