@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Edit Attendance Record";
}

<h1>Edit Attendance Record</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="CourseEnrolmentId" class="form-label"></label>
                <select asp-for="CourseEnrolmentId" asp-items="ViewBag.CourseEnrolmentId" class="form-select"></select>
                <span asp-validation-for="CourseEnrolmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WeekNumber" class="form-label"></label>
                <input asp-for="WeekNumber" class="form-control" />
                <span asp-validation-for="WeekNumber" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Present" class="form-check-input" />
                <label asp-for="Present" class="form-check-label"></label>
                <span asp-validation-for="Present" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>
