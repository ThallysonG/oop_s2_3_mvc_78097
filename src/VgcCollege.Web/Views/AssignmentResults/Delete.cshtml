@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Delete Assignment Result";
}

<h1>Delete Assignment Result</h1>

<h3>Are you sure you want to delete this?</h3>

<hr />

<dl class="row">
    <dt class="col-sm-2">Student</dt>
    <dd class="col-sm-10">@Model.StudentProfile?.Name</dd>

    <dt class="col-sm-2">Assignment</dt>
    <dd class="col-sm-10">@Model.Assignment?.Title</dd>

    <dt class="col-sm-2">Score</dt>
    <dd class="col-sm-10">@Model.Score</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
