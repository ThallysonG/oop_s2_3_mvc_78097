@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>

@{
    ViewData["Title"] = "My Assignment Results";
}

<h1>My Assignment Results</h1>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Assignment</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Score</th>
            <th>Feedback</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Assignment?.Title</td>
                <td>@item.Assignment?.Course?.Name</td>
                <td>@item.Assignment?.Course?.Branch?.Name</td>
                <td>@item.Score</td>
                <td>@item.Feedback</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>