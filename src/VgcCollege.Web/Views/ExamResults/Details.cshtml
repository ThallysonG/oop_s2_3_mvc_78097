@model VgcCollege.Web.Models.ExamResult

@{
    ViewData["Title"] = "Exam Result Details";
}

<h1>Exam Result Details</h1>

<hr />

<dl class="row">
    <dt class="col-sm-2">Student</dt>
    <dd class="col-sm-10">@Model.StudentProfile?.Name</dd>

    <dt class="col-sm-2">Exam</dt>
    <dd class="col-sm-10">@Model.Exam?.Title</dd>

    <dt class="col-sm-2">Course</dt>
    <dd class="col-sm-10">@Model.Exam?.Course?.Name</dd>

    <dt class="col-sm-2">Branch</dt>
    <dd class="col-sm-10">@Model.Exam?.Course?.Branch?.Name</dd>

    <dt class="col-sm-2">Score</dt>
    <dd class="col-sm-10">@Model.Score</dd>

    <dt class="col-sm-2">Grade</dt>
    <dd class="col-sm-10">@Model.Grade</dd>
</dl>

@if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
{
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
}

@if (User.IsInRole("Student"))
{
    <a asp-action="MyResults" class="btn btn-secondary">Back</a>
}
else
{
    <a asp-action="Index" class="btn btn-secondary">Back</a>
}
