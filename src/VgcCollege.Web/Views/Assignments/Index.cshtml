@model IEnumerable<VgcCollege.Web.Models.Assignment>

@{
    ViewData["Title"] = "Assignments";
}

<h1>Assignments</h1>

@if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Assignment</a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Course</th>
            <th>Branch</th>
            <th>Max Score</th>
            <th>Due Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Course?.Name</td>
                <td>@item.Course?.Branch?.Name</td>
                <td>@item.MaxScore</td>
                <td>@item.DueDate.ToString("yyyy-MM-dd")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Administrator") || User.IsInRole("Faculty"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    }

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
